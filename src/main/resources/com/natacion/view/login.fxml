<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.natacion.controller.LoginController"
      alignment="CENTER" spacing="18"
      style="-fx-background-color: #1a1a2e; -fx-padding: 60;">

    <Label text="🏊 Sistema de Natación"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #e0e0e0;"/>

    <Label text="Iniciar Sesión"
           style="-fx-font-size: 15px; -fx-text-fill: #a0a0c0;"/>

    <TextField fx:id="txtUsuario" promptText="Usuario"
               prefWidth="280"
               style="-fx-background-color: #16213e; -fx-text-fill: white;
                      -fx-prompt-text-fill: #666; -fx-background-radius: 6;
                      -fx-padding: 10; -fx-font-size: 13px; -fx-border-color: #3a3a6a;
                      -fx-border-radius: 6;"/>

    <PasswordField fx:id="txtPassword" promptText="Contraseña"
                   prefWidth="280"
                   style="-fx-background-color: #16213e; -fx-text-fill: white;
                          -fx-prompt-text-fill: #666; -fx-background-radius: 6;
                          -fx-padding: 10; -fx-font-size: 13px; -fx-border-color: #3a3a6a;
                          -fx-border-radius: 6;"/>

    <Label fx:id="lblError" text=""
           style="-fx-text-fill: #ff6b6b; -fx-font-size: 12px;"/>

    <HBox spacing="12" alignment="CENTER">
        <Button fx:id="btnIngresar" text="Ingresar"
                onAction="#ingresar"
                style="-fx-background-color: #4a4af0; -fx-text-fill: white;
                       -fx-background-radius: 6; -fx-padding: 10 30;
                       -fx-font-size: 13px; -fx-cursor: hand;"/>
        <Button fx:id="btnSalir" text="Salir"
                onAction="#salir"
                style="-fx-background-color: #555; -fx-text-fill: white;
                       -fx-background-radius: 6; -fx-padding: 10 30;
                       -fx-font-size: 13px; -fx-cursor: hand;"/>
    </HBox>
</VBox>
